# Fortel AI Takeoff — environment reference
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
# `run.sh` sources `.env` automatically if it exists (never commit `.env` — it is gitignored).
#
# Every variable below is read via os.getenv(...) with the default shown; the repo
# runs with NO .env at all and is safe to run locally with no configuration —
# APPROVAL_HOST already defaults to loopback-only, and with no APPROVAL_TOKEN/PORTAL_TOKEN
# set, the portal simply runs with no auth (fine for 127.0.0.1-only local use).

# ---------------------------------------------------------------------------
# Portal server (approval_server.py)
# ---------------------------------------------------------------------------

# Port the Flask portal listens on.
APPROVAL_PORT=5001

# Bind address. Code default is 127.0.0.1 (loopback-only) — this is a single-team,
# LAN-only deployment and the portal has no authentication unless PORTAL_TOKEN (below)
# is set. If APPROVAL_HOST is set to anything other than 127.0.0.1/localhost AND
# PORTAL_TOKEN is NOT set, the server refuses to bind that address and falls back to
# 127.0.0.1 (logging a warning) rather than silently exposing an unauthenticated portal
# to the LAN. Leave this at the default unless you also set PORTAL_TOKEN.
APPROVAL_HOST=127.0.0.1

# Shared-secret auth token, gating every route except /status (health-check) and the
# static /portal shell itself (an unauthenticated visitor to /portal sees an empty,
# non-functional page — its own fetch() calls still need the token). PORTAL_TOKEN is the
# current name; APPROVAL_TOKEN is accepted as an older alias (PORTAL_TOKEN wins if both
# are set). Required before APPROVAL_HOST can be set to anything other than
# 127.0.0.1/localhost.
#
# How it's presented/consumed once set:
#   - Bookmark the portal once as http://host:5001/portal?token=<this value> — that
#     request sets an httponly, SameSite=Lax cookie (30-day max-age) and redirects to the
#     clean /portal URL, so the token doesn't linger in browser history past the first visit.
#   - Every other route accepts the token via (in order checked): an
#     `Authorization: Bearer <token>` header, the cookie above, or a `?token=` query
#     parameter — the last of these is how emailed approve/reject/adjust links stay
#     authorised (approval_email.py appends ?token=... to every action link when this is set).
#   - Leave BLANK for local dev on 127.0.0.1 (auth fully disabled). Generate a real one
#     for any shared deployment: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   - The server's startup banner prints this masked (first 4 chars + …), never in full —
#     get the real value from this file, not from logs/portal.log.
PORTAL_TOKEN=

# Restrict cross-origin access to a single origin. The portal itself is served
# same-origin from /portal and does NOT need this set — only set it if a genuine
# cross-origin caller is added later (e.g. a browser-JS client on a different host).
# When unset, no CORS headers are sent at all (same-origin only). Never set to "*" —
# combined with cookie/token auth, a wildcard would let any page on the LAN drive
# /approve, /reject, etc. cross-origin.
APPROVAL_CORS_ORIGIN=

# Base URL used to build links in outbound approval emails (approval_email.py) and the
# n8n webhook response. MUST point at the machine other people will open the link from —
# "http://localhost:5001" only works for the person running the server.
APPROVAL_BASE_URL=http://localhost:5001

# How long (seconds) the background takeoff watchdog waits before marking a job
# UNMEASURED with a "PIPELINE TIMEOUT" flag so it never hangs forever.
TAKEOFF_TIMEOUT_S=120

# Where the jobs database lives. Default is ./approval_jobs.json next to
# approval_server.py. Override for a second/QA instance so it never collides with the
# live jobs file (see DEPLOY.md "Running a QA instance") — this env var IS read by both
# approval_server.py and approval_email.py.
JOBS_FILE=approval_jobs.json

# Where soft-deleted/archived jobs live (see the /archive endpoint). Defaults to
# "<JOBS_FILE stem>_archive.json" next to JOBS_FILE — e.g. approval_jobs.json ->
# approval_jobs_archive.json; approval_jobs.qa.json -> approval_jobs.qa_archive.json.
# Only set this if you want the archive somewhere other than that default (e.g. to force
# two differently-named JOBS_FILEs to share one archive — not recommended).
JOBS_ARCHIVE_FILE=

# Where daily rolling backups of JOBS_FILE are written (see approval_server._rotate_backup).
# Defaults to "backups/" next to JOBS_FILE for the live approval_jobs.json, or
# "backups_<JOBS_FILE stem>/" for any other JOBS_FILE (e.g. a QA instance) — so a QA run
# never writes into the live backups/ directory. Only set this to override that default.
BACKUP_DIR=

# ---------------------------------------------------------------------------
# Outbound approval emails (approval_email.py)
# ---------------------------------------------------------------------------

# Set to 1 to actually send approval-request emails from takeoff_pipeline.py.
# Defaults to 0 (off) so local/dev runs never spam real inboxes.
SEND_APPROVAL_EMAILS=0

# Who receives the approval-request email.
APPROVAL_TO=inderjit@fortel.co.uk

# SMTP relay used to send that email. If SMTP_PASS is blank, approval_email.py does not
# attempt to send — it saves the rendered HTML to approval_emails/<job_id>.html instead
# and logs the portal link, so local/dev runs never require a working SMTP relay.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=estimatingai@fortel.co.uk
SMTP_PASS=

# ---------------------------------------------------------------------------
# AI vision (llm_client.py / vision_llm.py)
# ---------------------------------------------------------------------------

# Required for UNMARKED-vector takeoffs (Claude vision region identification).
# Marked-vector (Bluebeam annotation) takeoffs do not need this at all.
ANTHROPIC_API_KEY=
